{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "package-name": "health-os",
      "changelog-path": "home-assistant-app/CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "home-assistant-app/config.yaml",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
